{
  "name": "cranberri",
  "version": "0.1.2",
  "description": "A chat-first coding cockpit for local repo work.",
  "author": "Dushyant Garg",
  "main": "out/main/index.cjs",
  "type": "module",
  "scripts": {
    "dev": "npm run build:metadata && electron-vite dev",
    "build": "npm run build:metadata && tsc --noEmit && eslint . --max-warnings 0 && npm run copy:updater-helper && electron-vite build",
    "build:packaged": "npm run build:metadata -- --packaged && tsc --noEmit && eslint . --max-warnings 0 && npm run copy:updater-helper && electron-vite build",
    "copy:updater-helper": "node -e \"const fs=require('fs'), path=require('path'); fs.mkdirSync('out/updater',{recursive:true}); fs.copyFileSync('scripts/updater/install-helper.mjs','out/updater/install-helper.mjs'); console.log('copied updater helper');\"",
    "build:metadata": "node scripts/build-metadata.mjs",
    "package": "npm run build:packaged && electron-builder",
    "package:dir": "npm run build:packaged && electron-builder --dir",
    "preview": "electron-vite preview",
    "lint": "npm run build:metadata && eslint . --max-warnings 0",
    "test": "npm run build:metadata && vitest run",
    "test:watch": "npm run build:metadata && vitest",
    "typecheck": "npm run build:metadata && tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-tabs": "^1.1.16",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-virtual": "^3.14.5",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "clsx": "^2.1.1",
    "fuse.js": "^7.4.2",
    "lucide-react": "^0.468.0",
    "node-pty": "^1.1.0",
    "parse-diff": "^0.12.0",
    "react": "^18.3.1",
    "react-diff-viewer-continued": "^4.2.2",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.3",
    "react-resizable-panels": "^4.12.1",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "simple-git": "^3.36.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.20",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^7.3.5",
    "vitest": "^4.1.9"
  }
}
